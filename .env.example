# =============================================================================
# ENVIRONMENT VARIABLES — copy to .env (dev) or .env.prod (production)
# =============================================================================
# All variables are documented below. Required vars have no default and
# will cause the app to fail fast on startup if missing.
#
# Dev setup:  cp .env.example .env   (then fill in your values)
# Prod setup: cp .env.example .env.prod  (fill in prod values)
#
# NEVER commit .env or .env.prod to git.
# =============================================================================


# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------
# Full Postgres connection string.
#
# Dev:  postgres://brain:brain@localhost:5435/brain_extension
#       (5435 = host port mapped in docker-compose.yml to avoid collisions)
#
# Prod: postgres://brain:STRONG_PASS@db:5432/brain_extension
#       ("db" is the Docker Compose service name — internal hostname)
#       No port mapping in prod — the app talks to Postgres internally.
DATABASE_URL=postgres://brain:brain@localhost:5435/brain_extension

# Postgres credentials (used by docker-compose.prod.yml to init the database).
# Must match what's in DATABASE_URL above.
# Dev: these are set directly in docker-compose.yml (no secrets needed locally).
# Prod: set strong values here and reference them in docker-compose.prod.yml.
POSTGRES_USER=brain
POSTGRES_PASSWORD=brain
POSTGRES_DB=brain_extension


# -----------------------------------------------------------------------------
# AUTHENTICATION
# -----------------------------------------------------------------------------
# Secret key for signing JWT session tokens.
# If this value changes, all existing sessions are invalidated (users must re-login).
# Generate a strong key: openssl rand -hex 32
JWT_SECRET=dev-secret-change-me-in-production


# -----------------------------------------------------------------------------
# AI — Inference server (embeddings + auto-tagging via Ollama)
# -----------------------------------------------------------------------------
# Provider-agnostic names — these work whether you're using Ollama, OpenAI, etc.
#
# Dev:  AI_BASE_URL=http://localhost:11434  (Ollama on your machine)
# Prod: AI_BASE_URL=http://ollama:11434     ("ollama" = Docker service name)
AI_BASE_URL=http://localhost:11434
EMBED_MODEL=nomic-embed-text
LLM_MODEL=llama3.2:1b


# -----------------------------------------------------------------------------
# AI — Chat (Anthropic Claude)
# -----------------------------------------------------------------------------
# Optional. If not set, the chat falls back to the local Ollama LLM.
# Get your key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here
CHAT_MODEL=claude-sonnet-4-6


# -----------------------------------------------------------------------------
# FILE STORAGE
# -----------------------------------------------------------------------------
# Which backend to use for uploaded images/files.
#
# "local"  — writes to public/uploads/ on disk. Next.js serves them as
#            static files. Easy for dev, but doesn't work in Docker prod
#            (the container's public/uploads/ isn't persistent).
#
# "minio"  — uploads to MinIO via the S3-compatible API. Files are persisted
#            in a Docker volume. Served via STORAGE_PUBLIC_URL.
#
# Dev default: local (no extra config needed)
# Prod:        minio (all STORAGE_* vars below become required)
STORAGE_PROVIDER=local

# MinIO / S3 settings — only needed when STORAGE_PROVIDER=minio
#
# STORAGE_ENDPOINT: the MinIO API URL (internal to Docker in prod)
#   Dev:  not needed
#   Prod: http://minio:9000
#
# STORAGE_ACCESS_KEY / STORAGE_SECRET_KEY:
#   Must match MINIO_ROOT_USER / MINIO_ROOT_PASSWORD below.
#
# STORAGE_BUCKET:
#   The bucket name. Create it once via MinIO console at :9001.
#   Default: brain-uploads
#
# STORAGE_PUBLIC_URL:
#   The public-facing base URL for serving files. Options:
#     a) Nginx proxies https://files.yourdomain.com → MinIO:9000/brain-uploads
#        → STORAGE_PUBLIC_URL=https://files.yourdomain.com/brain-uploads
#     b) Direct MinIO access (less ideal, exposes port)
#        → STORAGE_PUBLIC_URL=http://your-server-ip:9000/brain-uploads
#   The stored image_path in the DB becomes: STORAGE_PUBLIC_URL/filename.jpg
STORAGE_ENDPOINT=http://minio:9000
STORAGE_ACCESS_KEY=your-minio-access-key
STORAGE_SECRET_KEY=your-minio-secret-key
STORAGE_BUCKET=brain-uploads
STORAGE_PUBLIC_URL=https://files.yourdomain.com/brain-uploads


# -----------------------------------------------------------------------------
# MINIO — root credentials (used by docker-compose.prod.yml)
# -----------------------------------------------------------------------------
# These set the MinIO admin user on first boot.
# Must match STORAGE_ACCESS_KEY / STORAGE_SECRET_KEY above.
# Generate strong values: openssl rand -hex 16
MINIO_ROOT_USER=your-minio-access-key
MINIO_ROOT_PASSWORD=your-minio-secret-key


# -----------------------------------------------------------------------------
# APP
# -----------------------------------------------------------------------------
# The public URL of the app. Used for generating absolute URLs.
# Dev:  http://localhost:3000
# Prod: https://yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Secret for protecting cron job API endpoints (Phase 5).
# Cron callers include this in the Authorization: Bearer <token> header.
# Generate: openssl rand -hex 32
CRON_SECRET=your-cron-secret-here
