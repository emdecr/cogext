# Copy this file to .env.local and fill in your values.
# Next.js auto-loads .env.local for server-side code.
# Never commit .env or .env.local — they contain real credentials.

# Database connection string
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
# These values should match your docker-compose.yml
DATABASE_URL=postgres://USER:PASSWORD@HOST:PORT/DATABASE

# Secret key for signing JWT tokens.
# Generate one with: openssl rand -hex 32
JWT_SECRET=your-secret-key-here

# AI — inference server and model configuration
# Provider-agnostic names so they work whether you're using Ollama, OpenAI, etc.
AI_BASE_URL=http://localhost:11434
EMBED_MODEL=nomic-embed-text
LLM_MODEL=llama3.2:1b
