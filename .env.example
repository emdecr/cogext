# Copy this file to .env.local and fill in your values.
# Next.js auto-loads .env.local for server-side code.
# Never commit .env or .env.local — they contain real credentials.

# Database connection string
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
# These values should match your docker-compose.yml
DATABASE_URL=postgres://USER:PASSWORD@HOST:PORT/DATABASE

# Secret key for signing JWT tokens.
# Generate one with: openssl rand -hex 32
JWT_SECRET=your-secret-key-here

# Ollama — local AI inference server
# Default values work if running via the project's docker-compose.yml
OLLAMA_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_LLM_MODEL=llama3.2:1b
